{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "outDir": "./frontend/js",
    "rootDir": "./frontend/ts",
    "strict": true,
    "esModuleInterop": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "frontend/ts/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
